# =============================================================================
# Freelancer OS — Backend + Docker Compose variables
# Copy to .env (dev) or .env.production (prod). Never commit either.
# =============================================================================

# --- App ---------------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
PORT=3001

# DATABASE_URL is set automatically by docker-compose (points to db container).
# Only set this manually when running the backend outside Docker.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/freelancer_os?schema=public

# CORS — which frontend origin the backend accepts
FRONTEND_URL=http://localhost:3000

# --- Docker Compose (postgres container) --------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_change_me
POSTGRES_DB=freelancer_os

# Optional: expose postgres on a different host port (default 5432)
DB_PORT=5432

# --- Production only ----------------------------------------------------

# Pre-built image references for docker-compose.prod.yml
BACKEND_IMAGE=ghcr.io/your-github-username/freelancer-backend:latest
FRONTEND_IMAGE=ghcr.io/your-github-username/freelancer-frontend:latest

# Public URL where your backend API is reachable from the browser.
# This is baked into the frontend image at build time.
# Set before running: docker build --build-arg NEXT_PUBLIC_API_URL=...
NEXT_PUBLIC_API_URL=https://your-domain.com/api
